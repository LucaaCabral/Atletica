# Copie este arquivo para .env e preencha com os dados do seu projeto Supabase.
# Encontre-os em: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# NUNCA coloque a chave service_role aqui. Ela não deve existir no front-end.
